# Path to your Obsidian vault root (no trailing slash). Forward slashes work on Windows too.
# Leave unset to run with the committed sample-graph.json fallback.
VAULT_PATH=

# Subdirectory inside the vault to scan for the graph (relative to VAULT_PATH).
# Default: wiki
WIKI_SUBDIR=wiki

# Path to the Cleo .glb avatar. If absolute or starts with ../, the dev server will
# serve it via a custom middleware at /cleo.glb. Default: public/cleo.glb (committed).
CLEO_GLB_PATH=public/cleo.glb
